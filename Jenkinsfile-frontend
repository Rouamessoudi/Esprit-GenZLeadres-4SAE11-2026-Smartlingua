pipeline {
  agent any

  // Utilise Node.js et npm du PATH (WSL / agent), sans Global Tool Configuration Jenkins.

  environment {
    CHROME_BIN = '/usr/bin/google-chrome'
    SONAR_PROJECT_KEY = 'smartlingua-frontend'
  }

  options {
    timestamps()
    disableConcurrentBuilds()
  }

  parameters {
    string(name: 'DEPLOY_PATH', defaultValue: '/opt/smartlingua', description: 'Frontend deployment path on target server')
    string(name: 'DEPLOY_BRANCH', defaultValue: 'main', description: 'Git branch to deploy on target server')
  }

  stages {
    stage('Install') {
      steps {
        dir('frontend') {
          sh 'npm install'
        }
      }
    }

    stage('Build') {
      steps {
        dir('frontend') {
          sh 'npm run build'
        }
      }
    }

    stage('Test') {
      steps {
        dir('frontend') {
          sh 'npm test -- --watch=false --browsers=ChromeHeadless --code-coverage'
        }
      }
      post {
        always {
          junit allowEmptyResults: true, testResults: 'frontend/**/TESTS-*.xml'
          archiveArtifacts allowEmptyArchive: true, artifacts: 'frontend/coverage/**'
        }
      }
    }

    stage('SonarQube Frontend') {
      steps {
        withSonarQubeEnv('sonarqube') {
          sh '''
            set -e
            sonar-scanner \
              -Dsonar.projectKey=$SONAR_PROJECT_KEY \
              -Dsonar.projectName=SmartLingua Frontend \
              -Dsonar.sources=frontend/src \
              -Dsonar.tests=frontend/src \
              -Dsonar.test.inclusions=**/*.spec.ts \
              -Dsonar.exclusions=**/node_modules/**,**/dist/** \
              -Dsonar.javascript.lcov.reportPaths=frontend/coverage/**/lcov.info \
              -Dsonar.typescript.tsconfigPath=frontend/tsconfig.json
          '''
        }
      }
    }

    stage('Deploy Frontend') {
      when {
        anyOf {
          branch 'main'
          expression { return env.BRANCH_NAME == null } // Classic pipeline mode
        }
      }
      steps {
        withCredentials([
          string(credentialsId: 'frontend-deploy-host', variable: 'DEPLOY_HOST'),
          string(credentialsId: 'frontend-deploy-user', variable: 'DEPLOY_USER'),
          sshUserPrivateKey(credentialsId: 'frontend-deploy-ssh-key', keyFileVariable: 'SSH_KEY')
        ]) {
          sh '''
            set -e
            ssh -i "$SSH_KEY" -o StrictHostKeyChecking=no "$DEPLOY_USER@$DEPLOY_HOST" '
              set -e
              cd "${DEPLOY_PATH}"
              git fetch --all
              git checkout "${DEPLOY_BRANCH}"
              git pull origin "${DEPLOY_BRANCH}"
              if [ -f "docker-compose.yml" ]; then
                docker compose -f docker-compose.yml pull || true
                docker compose -f docker-compose.yml up -d
              else
                echo "No root docker-compose.yml found; frontend deploy finished with git update only."
              fi
            '
          '''
        }
      }
    }
  }

  post {
    success {
      echo 'Frontend CI/CD pipeline completed successfully.'
    }
    failure {
      echo 'Frontend CI/CD pipeline failed. Check logs.'
    }
  }
}
