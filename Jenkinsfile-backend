pipeline {
  agent any

  // Utilise JDK et Maven du PATH (WSL / agent), sans Global Tool Configuration Jenkins.

  environment {
    SONAR_PROJECT_KEY = 'smartlingua-backend'
  }

  options {
    timestamps()
    disableConcurrentBuilds()
  }

  parameters {
    string(name: 'DEPLOY_PATH', defaultValue: '/opt/smartlingua', description: 'Backend deployment path on target server')
    string(name: 'DEPLOY_BRANCH', defaultValue: 'main', description: 'Git branch to deploy on target server')
  }

  stages {
    stage('Test') {
      steps {
        script {
          def services = [
            'backend/apiGateway',
            'backend/config-server',
            'backend/eureka',
            'backend/microservices/users',
            'backend/microservices/forum',
            'backend/microservices/messaging',
            'backend/microservices/courses',
            'backend/microservices/quiz',
            'backend/microservices/exams',
            'backend/microservices/adaptive-learning',
            'backend/microservices/ai-assistant-service',
            'backend/microservices/privetcours'
          ]

          def branches = [:]
          for (int i = 0; i < services.size(); i++) {
            def svc = services[i]
            branches[svc] = {
              dir(svc) {
                sh '''
                  set -e
                  if [ -x "./mvnw" ]; then
                    ./mvnw test
                  else
                    mvn test
                  fi
                '''
              }
            }
          }
          parallel branches
        }
      }
    }

    stage('Build') {
      steps {
        script {
          def services = [
            'backend/apiGateway',
            'backend/config-server',
            'backend/eureka',
            'backend/microservices/users',
            'backend/microservices/forum',
            'backend/microservices/messaging',
            'backend/microservices/courses',
            'backend/microservices/quiz',
            'backend/microservices/exams',
            'backend/microservices/adaptive-learning',
            'backend/microservices/ai-assistant-service',
            'backend/microservices/privetcours'
          ]

          def branches = [:]
          for (int i = 0; i < services.size(); i++) {
            def svc = services[i]
            branches[svc] = {
              dir(svc) {
                sh '''
                  set -e
                  if [ -x "./mvnw" ]; then
                    ./mvnw clean package
                  else
                    mvn clean package
                  fi
                '''
              }
            }
          }
          parallel branches
        }
      }
      post {
        always {
          junit allowEmptyResults: true, testResults: '**/target/surefire-reports/*.xml'
          archiveArtifacts allowEmptyArchive: true, artifacts: '**/target/*.jar,**/target/site/jacoco/*.xml'
        }
      }
    }

    stage('SonarQube Backend') {
      steps {
        withSonarQubeEnv('sonarqube') {
          sh '''
            set -e
            mvn -f backend/apiGateway/pom.xml clean verify sonar:sonar \
              -Dsonar.projectKey=$SONAR_PROJECT_KEY \
              -Dsonar.projectName=SmartLingua Backend \
              -Dsonar.sources=backend \
              -Dsonar.tests=backend \
              -Dsonar.exclusions=**/target/**,**/.mvn/** \
              -Dsonar.coverage.jacoco.xmlReportPaths=backend/**/target/site/jacoco/jacoco.xml
          '''
        }
      }
    }

    stage('Deploy Backend') {
      when {
        anyOf {
          branch 'main'
          expression { return env.BRANCH_NAME == null } // Classic pipeline mode
        }
      }
      steps {
        withCredentials([
          string(credentialsId: 'backend-deploy-host', variable: 'DEPLOY_HOST'),
          string(credentialsId: 'backend-deploy-user', variable: 'DEPLOY_USER'),
          sshUserPrivateKey(credentialsId: 'backend-deploy-ssh-key', keyFileVariable: 'SSH_KEY')
        ]) {
          sh '''
            set -e
            ssh -i "$SSH_KEY" -o StrictHostKeyChecking=no "$DEPLOY_USER@$DEPLOY_HOST" '
              set -e
              cd "${DEPLOY_PATH}"
              git fetch --all
              git checkout "${DEPLOY_BRANCH}"
              git pull origin "${DEPLOY_BRANCH}"
              docker compose -f backend/docker-compose.yml pull || true
              docker compose -f backend/docker-compose.yml up -d
            '
          '''
        }
      }
    }
  }

  post {
    success {
      echo 'Backend CI/CD pipeline completed successfully.'
    }
    failure {
      echo 'Backend CI/CD pipeline failed. Check logs.'
    }
  }
}
